[submodule "dependencies/boltz-core"]
	path = dependencies/boltz-core
	url = git@github.com:BoltzExchange/boltz-core.git
	ignore = dirty
[submodule "dependencies/boltz-regtest"]
	path = dependencies/boltz-regtest
	url = git@github.com:BoltzExchange/regtest.git
[submodule "dependencies/nips/accommodation-nip"]
	path = dependencies/nips/accommodation-nip
	url = git@github.com:sudonym-btc/accommodation-nip.git
[submodule "dependencies/nips/order-nip"]
	path = dependencies/nips/order-nip
	url = git@github.com:sudonym-btc/order-nip.git
[submodule "dependencies/nips/escrow-nip"]
	path = dependencies/nips/escrow-nip
	url = git@github.com:sudonym-btc/escrow-nip.git
[submodule "ai/codex-marketplace"]
	path = ai/codex-marketplace
	url = git@github.com:sudonym-btc/hostr-codex.git
	branch = development
[submodule "dependencies/nips/marketplace-listing-nip"]
	path = dependencies/nips/marketplace-listing-nip
	url = git@github.com:sudonym-btc/marketplace-listing-nip.git
[submodule "dependencies/ndk"]
	path = dependencies/ndk
	url = git@github.com:sudonym-btc/ndk.git
	branch = marketplace
[submodule "dependencies/nostr-tools"]
	path = dependencies/nostr-tools
	url = git@github.com:sudonym-btc/nostr-tools.git
	branch = marketplace
