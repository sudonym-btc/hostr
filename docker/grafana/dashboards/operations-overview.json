                    "legendFormat": "{{hostr_operation_namespace}}"
                }
            ]
        },
        {
            "title": "Trace Search — Operations",
            "description": "Search for operation traces in Tempo by namespace, state or ID",
            "type": "traces",
            "gridPos": {
                "h": 12,
                "w": 24,
                "x": 0,
                "y": 8
            },
            "datasource": {
                "type": "tempo",
                "uid": "tempo"
            },
            "targets": [
                {
                    "refId": "A",
                    "datasource": {
                        "type": "tempo",
                        "uid": "tempo"
                    },
                    "queryType": "traceqlSearch",
                    "filters": [
                        {
                            "id": "service-name",
                            "tag": "service.name",
                            "operator": "=",
                            "scope": "resource"
                        },
                        {
                            "id": "op-namespace",
                            "tag": "hostr.operation.namespace",
                            "operator": "=",
                            "scope": "span"
                        },
                        {
                            "id": "op-state",
                            "tag": "hostr.operation.state",
                            "operator": "=",
                            "scope": "span"
                        },
                        {
                            "id": "status",
                            "tag": "status",
                            "operator": "=",
                            "scope": "intrinsic"
                        }
                    ],
                    "limit": 20
                }
            ]
        },
        {
            "title": "Operation State Distribution",
            "description": "Count of traces per operation state",
            "type": "piechart",
            "gridPos": {
                "h": 8,
                "w": 8,
                "x": 0,
                "y": 20
