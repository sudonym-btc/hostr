FROM ghcr.io/cirruslabs/flutter:stable AS build

WORKDIR /workspace

ARG APP_PROFILE=local
ARG GOOGLE_MAPS_API_KEY
ARG COMMIT_SHA=dev

ENV APP_PROFILE=$APP_PROFILE \
    GOOGLE_MAPS_API_KEY=$GOOGLE_MAPS_API_KEY \
    COMMIT_SHA=$COMMIT_SHA

COPY models /workspace/models
COPY hostr_sdk /workspace/hostr_sdk
COPY dependencies/google_maps_flutter_web /workspace/dependencies/google_maps_flutter_web
COPY app /workspace/app

WORKDIR /workspace/app

RUN flutter config --enable-web
RUN flutter pub get

RUN python3 - <<'PY'
from pathlib import Path
import os
import re
from urllib.parse import parse_qsl, urlencode, urlparse, urlunparse

key = os.environ['GOOGLE_MAPS_API_KEY']
index = Path('web/index.html')
text = index.read_text()
pattern = r'<script(?P<attrs>[^>]*)src="(?P<src>https://maps.googleapis.com/maps/api/js\?[^"]+)"(?P<tail>[^>]*)></script>'

def rewrite(match):
    src = match.group('src')
    parsed = urlparse(src)
    params = dict(parse_qsl(parsed.query, keep_blank_values=True))
    params['key'] = key
    params['loading'] = 'async'

    libraries = [lib for lib in params.get('libraries', '').split(',') if lib]
    if 'marker' not in libraries:
        libraries.append('marker')
    params['libraries'] = ','.join(libraries)

    new_src = urlunparse(parsed._replace(query=urlencode(params)))
    attrs = match.group('attrs')
    tail = match.group('tail')
    if ' async' not in f'{attrs}{tail}':
        attrs = f'{attrs} async'
    return f'<script{attrs}src="{new_src}"{tail}></script>'

text, count = re.subn(pattern, rewrite, text, count=1)
if count != 1:
    raise SystemExit('Failed to rewrite Google Maps script tag in web/index.html')
index.write_text(text)
PY

RUN case "$APP_PROFILE" in \
    *prod*|*production*) FLUTTER_TARGET="lib/main_production.dart" ;; \
    *staging*) FLUTTER_TARGET="lib/main_staging.dart" ;; \
    local|dev|development) FLUTTER_TARGET="lib/main_development.dart" ;; \
    *) echo "ERROR: Unknown APP_PROFILE='$APP_PROFILE'. Must be prod/staging/local." >&2; exit 1 ;; \
    esac \
    && flutter build web --release \
    --base-href="/" \
    --dart-define=COMMIT_SHA=$COMMIT_SHA \
    --target="$FLUTTER_TARGET"

FROM nginx:1.27-alpine AS runtime

COPY app/nginx.conf /etc/nginx/conf.d/default.conf
COPY --from=build /workspace/app/build/web /usr/share/nginx/html
